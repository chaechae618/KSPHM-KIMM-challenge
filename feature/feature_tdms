def time_domain_features(x, prefix):
    x = np.asarray(x, dtype=np.float64)
    abs_x = np.abs(x)

    rms = np.sqrt(np.mean(x ** 2))
    peak = np.max(abs_x)
    mean_abs = np.mean(abs_x)

    return {
        f"{prefix}_mean": np.mean(x),
        f"{prefix}_std": np.std(x),
        f"{prefix}_var": np.var(x),
        f"{prefix}_rms": rms,
        f"{prefix}_log_rms": np.log(rms + 1e-10),
        f"{prefix}_min": np.min(x),
        f"{prefix}_max": np.max(x),
        f"{prefix}_peak": peak,
        f"{prefix}_peak_to_peak": np.max(x) - np.min(x),
        f"{prefix}_mean_abs": mean_abs,
        f"{prefix}_energy": np.sum(x ** 2),
        f"{prefix}_skewness": skew(x),
        f"{prefix}_kurtosis": kurtosis(x, fisher=True),
        f"{prefix}_crest_factor": safe_div(peak, rms),
        f"{prefix}_shape_factor": safe_div(rms, mean_abs),
        f"{prefix}_impulse_factor": safe_div(peak, mean_abs),
        f"{prefix}_clearance_factor": safe_div(
            peak,
            np.mean(np.sqrt(abs_x)) ** 2
        ),
        f"{prefix}_zero_cross_rate": np.mean(np.diff(np.signbit(x)) != 0),
        f"{prefix}_q25": np.percentile(x, 25),
        f"{prefix}_q75": np.percentile(x, 75),
        f"{prefix}_iqr": np.percentile(x, 75) - np.percentile(x, 25),
        f"{prefix}_mad": np.mean(np.abs(x - np.mean(x))),
    }


def frequency_features(x, prefix, fs=FS):
    x = np.asarray(x, dtype=np.float64)
    fft_vals = np.abs(rfft(x)) / len(x)
    freqs = rfftfreq(len(x), d=1 / fs)

    power = fft_vals ** 2
    total_power = np.sum(power) + 1e-10

    centroid = np.sum(freqs * power) / total_power
    spread = np.sqrt(np.sum(((freqs - centroid) ** 2) * power) / total_power)
    p_norm = power / total_power

    # DC 제외 dominant freq
    if len(fft_vals) > 1:
        dom_idx = np.argmax(fft_vals[1:]) + 1
    else:
        dom_idx = 0

    features = {
        f"{prefix}_dom_freq": freqs[dom_idx],
        f"{prefix}_dom_amp": fft_vals[dom_idx],
        f"{prefix}_dom_ratio": safe_div(fft_vals[dom_idx], np.sum(fft_vals)),
        f"{prefix}_spec_centroid": centroid,
        f"{prefix}_spec_spread": spread,
        f"{prefix}_spec_skew": np.sum(((freqs - centroid) ** 3) * power) / ((spread ** 3) * total_power + 1e-10),
        f"{prefix}_spec_kurt": np.sum(((freqs - centroid) ** 4) * power) / ((spread ** 4) * total_power + 1e-10),
        f"{prefix}_spec_entropy": -np.sum(p_norm * np.log(p_norm + 1e-10)),
        f"{prefix}_spec_flatness": np.exp(np.mean(np.log(power + 1e-10))) / (np.mean(power) + 1e-10),
        f"{prefix}_rms_freq": np.sqrt(np.sum((freqs ** 2) * power) / total_power),
    }

    bands = [
        ("0_100", 0, 100),
        ("100_500", 100, 500),
        ("500_1k", 500, 1000),
        ("1k_3k", 1000, 3000),
        ("3k_5k", 3000, 5000),
        ("5k_10k", 5000, 10000),
        ("10k_12k8", 10000, 12800),
    ]

    for name, lo, hi in bands:
        mask = (freqs >= lo) & (freqs < hi)
        features[f"{prefix}_band_{name}_energy_ratio"] = np.sum(power[mask]) / total_power

    return features


def fault_frequency_features(x, prefix, rpm, fs=FS, bandwidth=5.0):
    """
    RPM 보정 결함 주파수 feature.
    1000rpm 기준 주파수에 현재 rpm/1000을 곱함.
    ±bandwidth Hz 주변 에너지 비율 추출.
    """
    x = np.asarray(x, dtype=np.float64)
    fft_vals = np.abs(rfft(x)) / len(x)
    freqs = rfftfreq(len(x), d=1 / fs)

    power = fft_vals ** 2
    total_power = np.sum(power) + 1e-10

    out = {}

    if pd.isna(rpm) or rpm <= 0:
        for fault_name in FAULT_FREQ_1000RPM:
            for h in [1, 2, 3]:
                out[f"{prefix}_{fault_name}_h{h}_freq"] = np.nan
                out[f"{prefix}_{fault_name}_h{h}_energy_ratio"] = np.nan
                out[f"{prefix}_{fault_name}_h{h}_peak_amp"] = np.nan
        return out

    for fault_name, base_freq in FAULT_FREQ_1000RPM.items():
        f0 = base_freq * rpm / 1000.0

        for h in [1, 2, 3]:
            target = f0 * h
            mask = (freqs >= target - bandwidth) & (freqs <= target + bandwidth)

            if mask.sum() == 0:
                energy_ratio = np.nan
                peak_amp = np.nan
            else:
                energy_ratio = np.sum(power[mask]) / total_power
                peak_amp = np.max(fft_vals[mask])

            out[f"{prefix}_{fault_name}_h{h}_freq"] = target
            out[f"{prefix}_{fault_name}_h{h}_energy_ratio"] = energy_ratio
            out[f"{prefix}_{fault_name}_h{h}_peak_amp"] = peak_amp

    return out


def envelope_features(x, prefix, fs=FS):
    """
    베어링 결함 검출용 envelope feature.
    필터 대역은 3000~10000Hz.
    """
    out = {}

    try:
        b, a = butter(4, [3000, 10000], btype="band", fs=fs)
        filtered = filtfilt(b, a, x)
        env = np.abs(hilbert(filtered))

        env_rms = np.sqrt(np.mean(env ** 2))
        env_peak = np.max(env)
        env_fft = np.abs(rfft(env)) / len(env)
        env_freqs = rfftfreq(len(env), d=1 / fs)
        env_power = env_fft ** 2
        total = np.sum(env_power) + 1e-10
        p_norm = env_power / total

        low_mask = env_freqs < 500
        low_fft = env_fft.copy()
        low_fft[~low_mask] = 0
        peak_f = env_freqs[np.argmax(low_fft)]

        out.update({
            f"{prefix}_env_mean": np.mean(env),
            f"{prefix}_env_std": np.std(env),
            f"{prefix}_env_rms": env_rms,
            f"{prefix}_env_peak": env_peak,
            f"{prefix}_env_kurtosis": kurtosis(env, fisher=True),
            f"{prefix}_env_skewness": skew(env),
            f"{prefix}_env_crest_factor": safe_div(env_peak, env_rms),
            f"{prefix}_env_energy": np.sum(env ** 2),
            f"{prefix}_env_low_energy_ratio": np.sum(env_power[low_mask]) / total,
            f"{prefix}_env_peak_freq": peak_f,
            f"{prefix}_env_peak_amp": np.max(low_fft),
            f"{prefix}_env_spec_centroid": np.sum(env_freqs * env_power) / total,
            f"{prefix}_env_spec_entropy": -np.sum(p_norm * np.log(p_norm + 1e-10)),
        })

    except Exception:
        keys = [
            "env_mean", "env_std", "env_rms", "env_peak", "env_kurtosis",
            "env_skewness", "env_crest_factor", "env_energy",
            "env_low_energy_ratio", "env_peak_freq", "env_peak_amp",
            "env_spec_centroid", "env_spec_entropy"
        ]
        for k in keys:
            out[f"{prefix}_{k}"] = np.nan

    return out


def wavelet_features(x, prefix):
    try:
        coeffs = pywt.wavedec(x, "db4", level=4)
        total_e = sum(np.sum(c ** 2) for c in coeffs) + 1e-10
        labels = ["cA4", "cD4", "cD3", "cD2", "cD1"]

        return {
            f"{prefix}_wav_{labels[i]}_energy_ratio": np.sum(coeffs[i] ** 2) / total_e
            for i in range(min(len(coeffs), len(labels)))
        }

    except Exception:
        return {
            f"{prefix}_wav_cA4_energy_ratio": np.nan,
            f"{prefix}_wav_cD4_energy_ratio": np.nan,
            f"{prefix}_wav_cD3_energy_ratio": np.nan,
            f"{prefix}_wav_cD2_energy_ratio": np.nan,
            f"{prefix}_wav_cD1_energy_ratio": np.nan,
        }


def cross_channel_features(ch_data):
    pairs = [
        ("CH1", "CH2"),
        ("CH1", "CH3"),
        ("CH1", "CH4"),
        ("CH2", "CH3"),
        ("CH2", "CH4"),
        ("CH3", "CH4"),
    ]

    out = {}
    for a, b in pairs:
        try:
            out[f"corr_{a}_{b}"] = np.corrcoef(ch_data[a], ch_data[b])[0, 1]
        except Exception:
            out[f"corr_{a}_{b}"] = np.nan

    return out


# ============================================================
# TDMS 1개 처리
# ============================================================

def extract_features_from_tdms(file_path, rpm=np.nan):
    tdms_file = TdmsFile.read(file_path)
    group = find_group(tdms_file)

    features = {}
    ch_data = {}

    for ch in CHANNELS:
        x = get_channel_data(group, ch)
        ch_data[ch] = x

        features.update(time_domain_features(x, ch))
        features.update(frequency_features(x, ch))
        features.update(fault_frequency_features(x, ch, rpm=rpm))
        features.update(envelope_features(x, ch))
        features.update(wavelet_features(x, ch))

        # 복합 feature
        features[f"{ch}_kurtosis_x_rms"] = features[f"{ch}_kurtosis"] * features[f"{ch}_rms"]
        features[f"{ch}_env_kurtosis_x_env_rms"] = features[f"{ch}_env_kurtosis"] * features[f"{ch}_env_rms"]

    features.update(cross_channel_features(ch_data))

    # 4채널 통합 feature
    rms_cols = [features[f"{ch}_rms"] for ch in CHANNELS]
    kurt_cols = [features[f"{ch}_kurtosis"] for ch in CHANNELS]
    env_kurt_cols = [features[f"{ch}_env_kurtosis"] for ch in CHANNELS]
    env_rms_cols = [features[f"{ch}_env_rms"] for ch in CHANNELS]

    features["rms_all_mean"] = np.mean(rms_cols)
    features["rms_all_max"] = np.max(rms_cols)
    features["kurtosis_all_mean"] = np.mean(kurt_cols)
    features["kurtosis_all_max"] = np.max(kurt_cols)
    features["env_kurtosis_all_mean"] = np.mean(env_kurt_cols)
    features["env_kurtosis_all_max"] = np.max(env_kurt_cols)
    features["env_rms_all_mean"] = np.mean(env_rms_cols)
    features["env_rms_all_max"] = np.max(env_rms_cols)

    return features


