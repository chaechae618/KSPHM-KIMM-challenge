def add_rul_label(df):
    """
    Q&A 기준: operation.csv 마지막 시간이 아니라 TDMS 기준으로 수명 산정.
    마지막 TDMS 종료시각 = failure time.
    RUL = failure_time - 현재 time_end_sec
    """
    df = df.copy()
    failure_time = df["time_end_sec"].max()
    df["failure_time_sec_tdms"] = failure_time
    df["RUL_sec"] = failure_time - df["time_end_sec"]
    return df


def add_si_and_relative_features(df):
    """
    상태지수:
    - 진동: 초기 정상상태 평균 대비 정규화
    - 온도: 200℃ 기준
    - 토크: 20Nm 기준
    """
    df = df.copy()

    # RPM 그룹
    df["rpm_group"] = (df["op_rpm_mean"] >= 850).astype("float")
    df.loc[df["op_rpm_mean"].isna(), "rpm_group"] = np.nan

    # train별 초기 6개 파일 baseline
    for tid in df["train_id"].unique():
        mask = df["train_id"] == tid
        sub = df.loc[mask].sort_values("file_index")

        # CH별 초기 RMS baseline
        for ch in CHANNELS:
            init_rms = sub[f"{ch}_rms"].iloc[:6].mean()
            df.loc[mask, f"{ch}_rms_rel_init6"] = df.loc[mask, f"{ch}_rms"] / (init_rms + 1e-10)

        init_rms_all = sub["rms_all_mean"].iloc[:6].mean()

        df.loc[mask, "V_norm"] = df.loc[mask, "rms_all_mean"] / (init_rms_all + 1e-10)
        df.loc[mask, "T_norm"] = df.loc[mask, "op_temp_front"] / 200.0
        df.loc[mask, "Tor_norm"] = df.loc[mask, "op_torque_mean"].abs() / 20.0

        df.loc[mask, "SI"] = (
            1.0 * df.loc[mask, "V_norm"]
            + 0.1 * df.loc[mask, "T_norm"]
            + 0.1 * df.loc[mask, "Tor_norm"]
        )

        # RPM 그룹 내 초기값 대비 정규화
        for grp in [0, 1]:
            gmask = mask & (df["rpm_group"] == grp)
            gsub = df.loc[gmask].sort_values("file_index")
            if len(gsub) < 3:
                continue

            for ch in CHANNELS:
                init_val = gsub[f"{ch}_rms"].iloc[:3].mean()
                df.loc[gmask, f"{ch}_rms_rel_rpm_group"] = df.loc[gmask, f"{ch}_rms"] / (init_val + 1e-10)

            init_env = gsub["env_rms_all_mean"].iloc[:3].mean()
            df.loc[gmask, "env_rms_all_rel_rpm_group"] = df.loc[gmask, "env_rms_all_mean"] / (init_env + 1e-10)

    return df


def rolling_slope(values, window):
    values = np.asarray(values, dtype=np.float64)
    out = np.full(len(values), np.nan)

    for i in range(len(values)):
        start = max(0, i - window + 1)
        y = values[start:i + 1]

        if len(y) < 3 or np.all(np.isnan(y)):
            continue

        x = np.arange(len(y))
        valid = ~np.isnan(y)

        if valid.sum() < 3:
            continue

        out[i] = np.polyfit(x[valid], y[valid], 1)[0]

    return out


def add_trend_features(df):
    df = df.copy()
    df = df.sort_values(["train_id", "file_index"]).reset_index(drop=True)

    trend_cols = [
        "rms_all_mean",
        "rms_all_max",
        "kurtosis_all_mean",
        "env_kurtosis_all_max",
        "env_rms_all_mean",
        "SI",
        "op_temp_front",
        "op_temp_rear",
        "op_torque_mean",
    ]

    # 결함주파수 대표 feature도 trend에 포함
    for ch in CHANNELS:
        for fault in ["bpfi", "bpfo", "bsf"]:
            col = f"{ch}_{fault}_h1_energy_ratio"
            if col in df.columns:
                trend_cols.append(col)

    for tid in df["train_id"].unique():
        mask = df["train_id"] == tid
        sub = df.loc[mask].sort_values("file_index")

        for col in trend_cols:
            if col not in df.columns:
                continue

            vals = sub[col].values
            df.loc[sub.index, f"{col}_slope_3"] = rolling_slope(vals, 3)
            df.loc[sub.index, f"{col}_slope_6"] = rolling_slope(vals, 6)

            # 최근 3/6개 rolling mean도 추가
            df.loc[sub.index, f"{col}_rollmean_3"] = pd.Series(vals).rolling(3, min_periods=1).mean().values
            df.loc[sub.index, f"{col}_rollmean_6"] = pd.Series(vals).rolling(6, min_periods=1).mean().values

    return df


# ============================================================
# Train 폴더 처리
# ============================================================

def process_train_folder(train_name, folder_path):
    print(f"\n처리 시작: {train_name}")
    print(f"경로: {folder_path}")

    if not os.path.exists(folder_path):
        print(f"폴더 없음: {folder_path}")
        return None

    tdms_files = sorted(
        [f for f in os.listdir(folder_path) if f.lower().endswith(".tdms")],
        key=get_file_index
    )

    if len(tdms_files) == 0:
        print("TDMS 파일 없음")
        return None

    print(f"TDMS 파일 수: {len(tdms_files)}")

    # operation 먼저 읽어서 rpm을 feature 추출에 활용
    op_raw = load_operation_csv(train_name)
    op = standardize_operation_columns(op_raw)

    rows = []

    for fname in tqdm(tdms_files, desc=train_name):
        file_path = os.path.join(folder_path, fname)
        file_idx = get_file_index(fname)

        time_start = (file_idx - 1) * 600
        time_end = (file_idx - 1) * 600 + 60

        # rpm 추정: operation에서 가장 가까운 rpm 사용
        rpm_for_fft = np.nan
        if op is not None and "op_time_sec" in op.columns and "op_rpm_mean" in op.columns:
            tmp = op.iloc[(op["op_time_sec"] - time_end).abs().argsort()[:1]]
            if len(tmp) > 0:
                rpm_for_fft = float(tmp["op_rpm_mean"].iloc[0])

        try:
            feats = extract_features_from_tdms(file_path, rpm=rpm_for_fft)
            feats["train_id"] = train_name
            feats["file_index"] = file_idx
            feats["file_name"] = fname
            feats["time_start_sec"] = time_start
            feats["time_end_sec"] = time_end
            rows.append(feats)

        except Exception as e:
            print(f"오류: {fname} / {e}")

    df = pd.DataFrame(rows)
    df = df.sort_values("file_index").reset_index(drop=True)

    # operation feature 결합
    df = attach_operation_features(df, op)

    # RUL label
    df = add_rul_label(df)

    return df


# ============================================================
# 전체 실행
# ============================================================

def main():
    all_dfs = []

    for train_name, folder_path in TRAIN_FOLDERS.items():
        df = process_train_folder(train_name, folder_path)

        if df is None or len(df) == 0:
            continue

        out_each = os.path.join(OUTPUT_DIR, f"{train_name}_features_raw.csv")
        df.to_csv(out_each, index=False, encoding="utf-8-sig")
        print(f"저장 완료: {out_each}")
        print(f"{train_name}: {df.shape[0]} rows x {df.shape[1]} cols")

        all_dfs.append(df)

    if not all_dfs:
        print("처리된 데이터가 없습니다.")
        return

    all_df = pd.concat(all_dfs, ignore_index=True)

    # 통합 후 train별 상대 feature, SI, trend 생성
    all_df = add_si_and_relative_features(all_df)
    all_df = add_trend_features(all_df)

    # 컬럼 순서 정리
    meta_cols = [
        "train_id",
        "file_index",
        "file_name",
        "time_start_sec",
        "time_end_sec",
        "failure_time_sec_tdms",
        "RUL_sec",
        "op_time_sec",
        "op_rpm_mean",
        "rpm_group",
        "op_torque_mean",
        "op_temp_front",
        "op_temp_rear",
        "V_norm",
        "T_norm",
        "Tor_norm",
        "SI",
    ]

    meta_cols = [c for c in meta_cols if c in all_df.columns]
    feat_cols = [c for c in all_df.columns if c not in meta_cols]
    all_df = all_df[meta_cols + feat_cols]

    out_all = os.path.join(OUTPUT_DIR, "ALL_train_features_final.csv")
    all_df.to_csv(out_all, index=False, encoding="utf-8-sig")

    print("\n전체 완료")
    print(f"저장 파일: {out_all}")
    print(f"최종 크기: {all_df.shape[0]} rows x {all_df.shape[1]} cols")

    # 간단 검증용 출력
    print("\n핵심 컬럼 확인")
    check_cols = [
        "train_id", "file_index", "RUL_sec", "op_rpm_mean",
        "rms_all_mean", "V_norm", "T_norm", "Tor_norm", "SI",
        "CH1_bpfi_h1_energy_ratio", "CH1_bpfo_h1_energy_ratio",
        "rms_all_mean_slope_6", "op_temp_front_slope_6"
    ]
    check_cols = [c for c in check_cols if c in all_df.columns]
    print(all_df[check_cols].head(10))


if __name__ == "__main__":
    main()
