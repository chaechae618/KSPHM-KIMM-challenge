def load_operation_csv(train_name):
    """
    operation.csv 경로가 다를 수 있어서 후보 경로 여러 개 탐색.
    인코딩 문제 방지를 위해 여러 encoding으로 시도.
    """
    candidates = [
        os.path.join(BASE, f"{train_name}_operation.csv"),
        os.path.join(BASE, f"{train_name}_Operation.csv"),
        os.path.join(BASE, f"{train_name}_operation", "operation.csv"),
        os.path.join(BASE, f"{train_name}_Operation", "operation.csv"),
        os.path.join(BASE, train_name, "operation.csv"),
        os.path.join(BASE, f"{train_name}_Vibration", "operation.csv"),
        os.path.join(BASE, f"{train_name}_Vibration", f"{train_name}_operation.csv"),
        os.path.join(BASE, f"{train_name}_Vibration", f"{train_name}_Operation.csv"),
    ]

    for path in candidates:
        if os.path.exists(path):
            print(f"operation.csv 발견: {path}")
            op = read_csv_safely(path)
            op.columns = [str(c).strip() for c in op.columns]
            return op

    print(f"{train_name}: operation.csv 없음. 진동 feature만 추출합니다.")
    return None


def standardize_operation_columns(op):
    """
    operation.csv 컬럼명이 정확히 다를 수 있으므로 최대한 자동 매핑.
    """
    if op is None:
        return None

    cols = op.columns.tolist()

    def find_col(keywords):
        for c in cols:
            cl = str(c).lower()
            if all(k.lower() in cl for k in keywords):
                return c
        return None

    time_col = find_col(["time"]) or find_col(["sec"])
    torque_col = find_col(["torque"])
    rpm_col = find_col(["speed"]) or find_col(["rpm"])
    front_col = find_col(["front"])
    rear_col = find_col(["rear"])

    rename = {}
    if time_col:
        rename[time_col] = "op_time_sec"
    if torque_col:
        rename[torque_col] = "op_torque_mean"
    if rpm_col:
        rename[rpm_col] = "op_rpm_mean"
    if front_col:
        rename[front_col] = "op_temp_front"
    if rear_col:
        rename[rear_col] = "op_temp_rear"

    op = op.rename(columns=rename)

    keep = [
        c for c in [
            "op_time_sec",
            "op_torque_mean",
            "op_rpm_mean",
            "op_temp_front",
            "op_temp_rear"
        ]
        if c in op.columns
    ]

    op = op[keep].copy()

    # 숫자형 변환
    for c in op.columns:
        op[c] = pd.to_numeric(op[c], errors="coerce")

    return op


def attach_operation_features(df, op):
    """
    TDMS 측정 종료시간에 가장 가까운 operation row를 붙임.
    operation.csv가 없으면 NaN으로 채움.
    """
    df = df.copy()

    if op is None or "op_time_sec" not in op.columns:
        for c in ["op_torque_mean", "op_rpm_mean", "op_temp_front", "op_temp_rear"]:
            if c not in df.columns:
                df[c] = np.nan
        return df

    op = op.dropna(subset=["op_time_sec"]).sort_values("op_time_sec").reset_index(drop=True)
    df = df.sort_values("time_end_sec").reset_index(drop=True)

    df = pd.merge_asof(
        df,
        op,
        left_on="time_end_sec",
        right_on="op_time_sec",
        direction="nearest",
        tolerance=600
    )

    for c in ["op_torque_mean", "op_rpm_mean", "op_temp_front", "op_temp_rear"]:
        if c not in df.columns:
            df[c] = np.nan

    return df


